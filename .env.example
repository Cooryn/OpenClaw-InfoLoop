# Qwen / DashScope API
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# WeChat Official Account
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here
WECHAT_AUTHOR=InfoLoop Bot
WECHAT_CONTENT_SOURCE_URL=
WECHAT_COVER_IMAGE_PATH=
WECHAT_COVER_MEDIA_ID=
WECHAT_SHOW_COVER_PIC=true

# SMTP Email
SMTP_HOST=smtp.example.com
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here
TARGET_EMAIL=recipient@example.com

# Optional proxy for outbound requests.
# Runtime should read PROXY_URL first, then fall back to HTTP_PROXY.
PROXY_URL=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890

# Optional model override for long-form generation
CONTENT_STUDIO_MODEL=qwen-plus
